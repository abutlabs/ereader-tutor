{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.15.0",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.15.0",
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.15.0",
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal"
      }
    }
  }
}
